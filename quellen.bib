  volume   = {26},
  abstract = {For the investigation of the frequency and voltage dependence of the load self-acting data acquisition systems have been installed and operated for more than two years in eight load part systems in Germany and France. The data acquisition systems and the evaluation procedure developped for this purpose are described as well as the identified load parameters. Furtheron there will be shown the great influence of the frequency and voltage dependence of the load on the control behaviour of isolated and interconnected power systems especially during emergency conditions},
